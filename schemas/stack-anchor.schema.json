{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fabric-db.github.io/platform-As-a-Book/schemas/stack-anchor.schema.json",
  "title": "Platform Stack Anchor",
  "type": "object",
  "required": [
    "id",
    "kind",
    "version",
    "anchor",
    "gate",
    "substrate",
    "doors",
    "ledger",
    "meaning",
    "governance",
    "required_artifacts"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 3
    },
    "kind": {
      "const": "platform.stack.anchor"
    },
    "version": {
      "type": "string"
    },
    "anchor": {
      "const": "book-stack"
    },
    "gate": {
      "const": "release-gate"
    },
    "substrate": {
      "const": "anydb"
    },
    "doors": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "ledger": {
      "const": "bookkeeper"
    },
    "meaning": {
      "const": "fabric"
    },
    "governance": {
      "const": "agennext"
    },
    "required_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 3
      }
    }
  },
  "additionalProperties": false
}

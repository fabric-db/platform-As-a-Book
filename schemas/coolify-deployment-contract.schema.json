{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fabric-db.github.io/platform-As-a-Book/schemas/coolify-deployment-contract.schema.json",
  "title": "Coolify Deployment Contract",
  "type": "object",
  "required": [
    "id",
    "kind",
    "version",
    "platform",
    "source",
    "services",
    "environment",
    "release",
    "evidence",
    "ownership"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 3
    },
    "kind": {
      "const": "coolify.deployment.contract"
    },
    "version": {
      "type": "string"
    },
    "platform": {
      "const": "coolify"
    },
    "source": {
      "type": "object",
      "required": ["type", "repository", "handoff"],
      "properties": {
        "type": {
          "enum": ["git", "image", "compose"]
        },
        "repository": {
          "type": "string",
          "minLength": 3
        },
        "handoff": {
          "type": "string",
          "minLength": 3
        }
      },
      "additionalProperties": true
    },
    "services": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "type", "health_path", "stateful"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 3
          },
          "type": {
            "enum": ["application", "worker", "database", "policy", "identity", "gateway"]
          },
          "image": {
            "type": "string"
          },
          "image_variable": {
            "type": "string"
          },
          "port": {
            "type": "integer",
            "minimum": 1,
            "maximum": 65535
          },
          "health_path": {
            "type": "string"
          },
          "stateful": {
            "type": "boolean"
          },
          "volume": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "environment": {
      "type": "object",
      "required": ["required"],
      "properties": {
        "required": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 2
          }
        }
      },
      "additionalProperties": false
    },
    "release": {
      "type": "object",
      "required": ["strategy", "rollback_required", "commit_sha_required", "deployment_id_required"],
      "properties": {
        "strategy": {
          "enum": ["source-handoff", "image-handoff", "manual-compose"]
        },
        "rollback_required": {
          "type": "boolean",
          "const": true
        },
        "commit_sha_required": {
          "type": "boolean",
          "const": true
        },
        "deployment_id_required": {
          "type": "boolean",
          "const": true
        }
      },
      "additionalProperties": false
    },
    "evidence": {
      "type": "object",
      "required": ["logs_required", "health_required", "operator_action_required"],
      "properties": {
        "logs_required": {
          "type": "boolean",
          "const": true
        },
        "health_required": {
          "type": "boolean",
          "const": true
        },
        "operator_action_required": {
          "type": "boolean",
          "const": true
        }
      },
      "additionalProperties": false
    },
    "ownership": {
      "type": "object",
      "required": ["runtime_owner", "policy_owner", "data_classification"],
      "properties": {
        "runtime_owner": {
          "type": "string",
          "minLength": 3
        },
        "policy_owner": {
          "type": "string",
          "minLength": 3
        },
        "data_classification": {
          "type": "string",
          "minLength": 3
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fabric-db.github.io/platform-As-a-Book/schemas/anydata-envelope.schema.json",
  "title": "AnyData Envelope",
  "type": "object",
  "required": [
    "id",
    "kind",
    "source",
    "data_type",
    "schema_ref",
    "policy_ref",
    "evidence_ref",
    "trust_state",
    "created_at"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 3
    },
    "kind": {
      "const": "anydata.envelope"
    },
    "source": {
      "type": "string",
      "minLength": 2
    },
    "data_type": {
      "type": "string",
      "minLength": 2
    },
    "schema_ref": {
      "type": "string",
      "minLength": 3
    },
    "policy_ref": {
      "type": "string",
      "minLength": 3
    },
    "evidence_ref": {
      "type": "string",
      "minLength": 3
    },
    "trust_state": {
      "enum": ["unverified", "verified", "blocked"]
    },
    "created_at": {
      "type": "string"
    },
    "payload": {
      "type": "object"
    }
  },
  "additionalProperties": false
}

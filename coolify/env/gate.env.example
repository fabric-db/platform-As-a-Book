# Gate handoff config used by the reconciler and release gate.

COOLIFY_URL=https://coolify.example.com
COOLIFY_SERVER_UUID=replace-me
COOLIFY_PROJECT_UUID=replace-me
COOLIFY_ENVIRONMENT_NAME=production

# Secret value. Store in GitHub Actions or Coolify, not in the book.
COOLIFY_TOKEN=replace-me

# Endpoint paths are configurable because Coolify API paths can evolve.
COOLIFY_CREATE_DOCKER_COMPOSE_PATH=/api/v1/applications/dockercompose
COOLIFY_DEPLOY_PATH=/api/v1/deploy

# Keep true for validation-only handoff.
DRY_RUN=true

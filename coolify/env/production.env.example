# Coolify production environment config for platform-as-a-book-stack.
# Copy these values into the Coolify app environment.

AGENT_API_IMAGE=ghcr.io/agennext/agennext-agent-api
AGENT_WORKER_IMAGE=ghcr.io/agennext/agennext-agent-worker
IMAGE_TAG=latest

DATABASE_URL=http://anydb:8000
OPA_URL=http://opa:8181
OPENFGA_API_URL=http://openfga:8080
AGENT_IDENTITY_ISSUER=https://identity.example.com

SURREAL_ROOT_USER=replace-me
SURREAL_ROOT_PASS=replace-me

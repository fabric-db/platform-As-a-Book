{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fabric-db.github.io/platform-As-a-Book/schemas/platform-binding.schema.json",
  "title": "Platform Binding Gate",
  "type": "object",
  "required": ["id", "kind", "version", "gate", "bindings", "required_artifacts"],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 3
    },
    "kind": {
      "const": "platform.binding.gate"
    },
    "version": {
      "type": "string"
    },
    "gate": {
      "type": "object",
      "required": ["name", "required", "mode"],
      "properties": {
        "name": {
          "const": "release-gate"
        },
        "required": {
          "type": "boolean",
          "const": true
        },
        "mode": {
          "const": "deny-on-missing-binding"
        }
      },
      "additionalProperties": false
    },
    "bindings": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "object",
        "required": ["from", "to", "relation", "evidence"],
        "properties": {
          "from": {
            "type": "string",
            "minLength": 2
          },
          "to": {
            "type": "string",
            "minLength": 2
          },
          "relation": {
            "type": "string",
            "minLength": 3
          },
          "evidence": {
            "type": "string",
            "minLength": 3
          }
        },
        "additionalProperties": false
      }
    },
    "required_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 3
      }
    }
  },
  "additionalProperties": false
}
